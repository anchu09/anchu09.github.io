---
import { icons, iconClass } from '../data/icons'

interface Props {
  title: string
  description: string
  tags: string[]
  github?: string
  liveUrl?: string
  year: string
  badges?: string[]
  slug: string
}

const { title, description, tags, github, liveUrl, year, badges, slug } = Astro.props
const externalLink = liveUrl ?? github

const badgeColors: Record<string, string> = {
  'Computer Vision & Generative AI': 'bg-amber-500/20 text-amber-300 border-amber-500/30',
  'Generative AI':                   'bg-amber-500/20 text-amber-300 border-amber-500/30',
  'Computer Vision':                 'bg-violet-500/20 text-violet-300 border-violet-500/30',
  'Data Science':                    'bg-rose-500/20 text-rose-300 border-rose-500/30',
  'Virtual Reality':                 'bg-blue-500/20 text-blue-300 border-blue-500/30',
  'Deep Learning':                   'bg-emerald-500/20 text-emerald-300 border-emerald-500/30',
}

const cardColors: Record<string, string> = {
  'Computer Vision & Generative AI': 'border-amber-500/30 hover:border-amber-500/60 bg-amber-500/[0.05]',
  'Generative AI':                   'border-amber-500/30 hover:border-amber-500/60 bg-amber-500/[0.05]',
  'Computer Vision':                 'border-violet-500/30 hover:border-violet-500/60 bg-violet-500/[0.05]',
  'Data Science':                    'border-rose-500/30 hover:border-rose-500/60 bg-rose-500/[0.05]',
  'Virtual Reality':                 'border-blue-500/30 hover:border-blue-500/60 bg-blue-500/[0.05]',
  'Deep Learning':                   'border-emerald-500/30 hover:border-emerald-500/60 bg-emerald-500/[0.05]',
}

const primaryBadge = badges?.[0] ?? ''
const cardBorder = cardColors[primaryBadge] ?? 'border-white/5 hover:border-indigo-500/30'
---

<article class={`card-hover group relative border rounded-2xl p-6 flex flex-col gap-4 transition-colors ${cardBorder}`}>

  <!-- stretched link covers the whole card -->
  <a href={`/projects/${slug}#hero-end`} class="absolute inset-0 rounded-2xl z-10" aria-label={`View ${title}`}></a>

  <!-- External link top-right: SideQuest icon if liveUrl, GitHub icon otherwise -->
  {externalLink && (
    <a
      href={externalLink}
      target="_blank"
      rel="noopener noreferrer"
      class="absolute top-5 right-5 z-20 text-slate-500 hover:text-white transition-colors"
      aria-label={liveUrl ? 'SideQuest' : 'GitHub'}
    >
      {liveUrl ? (
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      ) : (
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      )}
    </a>
  )}

  <div class="flex flex-col gap-2 relative z-0">
    <div class="flex items-baseline gap-2">
      <h3 class="font-semibold text-white group-hover:text-indigo-300 transition-colors">{title}</h3>
      <span class="text-xs text-slate-500 shrink-0">{year}</span>
    </div>
    {badges && badges.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {badges.map(b => (
          <span class={`text-xs px-2 py-0.5 rounded-full border ${badgeColors[b] ?? 'bg-white/5 text-slate-400 border-white/10'}`}>
            {b}
          </span>
        ))}
      </div>
    )}
  </div>

  <p class="text-slate-400 text-sm leading-relaxed flex-1">{description}</p>

  <div class="flex items-center justify-between">
    <div class="flex flex-wrap gap-2">
      {tags.slice(0, 4).map(tag => (
        <span class="flex items-center gap-1 text-xs px-2.5 py-0.5 rounded-full bg-white/5 text-slate-300 border border-white/10">
          {icons[tag] && <img src={icons[tag]} alt="" class={`shrink-0 ${iconClass(icons[tag])}`} />}
          {tag}
        </span>
      ))}
      {tags.length > 4 && (
        <span class="text-xs px-2 py-0.5 text-slate-600">+{tags.length - 4}</span>
      )}
    </div>
    <span class="text-xs text-slate-600 group-hover:text-indigo-400 transition-colors shrink-0 ml-2">View →</span>
  </div>

</article>
