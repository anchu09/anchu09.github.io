<section class="min-h-screen flex items-center pt-16">
  <div class="max-w-7xl mx-auto px-6 py-24">
    <p class="text-indigo-400 font-medium mb-4 tracking-wide text-sm uppercase">AI Engineer</p>
    <h1 class="text-5xl md:text-7xl font-bold text-white leading-tight mb-6">
      Daniel<br />
      <span class="gradient-text">Anchuela</span>
    </h1>
    <p id="hero-tagline" class="text-lg md:text-xl text-slate-400 max-w-2xl leading-relaxed mb-10" style="opacity:0">
      AI Engineer specializing in Generative AI and Computer Vision.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="#projects"
        class="magnetic-btn px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg font-medium transition-colors duration-200"
      >
        View Projects
      </a>
      <a
        href="https://github.com/anchu09"
        target="_blank"
        rel="noopener noreferrer"
        class="magnetic-btn px-6 py-3 border border-white/10 hover:border-white/30 text-slate-300 hover:text-white rounded-lg font-medium transition-colors duration-200"
      >
        GitHub
      </a>
      <a
        href="/cv.pdf"
        download="CV_Daniel_Anchuela.pdf"
        class="magnetic-btn px-6 py-3 border border-white/10 hover:border-white/30 text-slate-300 hover:text-white rounded-lg font-medium transition-colors duration-200 flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V4" />
        </svg>
        CV
      </a>
    </div>


  </div>
</section>
