---
const links = [
  { href: '#about', label: 'About' },
  { href: '#education', label: 'Education' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#publications', label: 'Publications' },
  { href: '#beyond', label: 'Beyond the Code' },
  { href: '#contact', label: 'Contact' },
]
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/[0.03] backdrop-blur-md border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#" class="font-semibold text-white tracking-tight">Daniel Anchuela</a>
    <ul class="flex gap-6">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm text-slate-400 hover:text-white transition-colors duration-200"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
