---
const cards = [
  {
    title: 'Astronomy & Astrophysics',
    subtitle: 'M82 & M81 · Captured from Spain',
    description: 'Astrophoto I captured during a night observation session. Astronomy is one of my deepest passions — and the inspiration behind AstronomIA, my AI chatbot for deep-space image analysis.',
    image: '/astronomy.png',
    placeholder: false,
  },
  {
    title: 'Ex Semi-pro Footballer',
    subtitle: 'Cambrils UCF',
    description: 'Played semi-professionally for Cambrils UCF, where I was also team captain. Football has been a big part of my life for many years.',
    image: '/football.png',
    placeholder: false,
  },
  {
    title: 'Geography Enthusiast',
    subtitle: 'Countries, cities, flags & more',
    description: 'Passionate about geography since childhood — countries, capitals, flags and cultures. A genuine curiosity for how the world is organized.',
    image: '/globe_map_hands.jpg',
    placeholder: false,
  },
  {
    title: 'Cat Colony Caretaker',
    subtitle: 'Local cat welfare volunteer',
    description: 'For years I looked after a colony of stray cats for a local welfare association — making sure they were fed, healthy and sterilized.',
    image: '/cats.jpg',
    placeholder: false,
  },
]
---

<section id="beyond" class="py-24 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-white mb-3">Beyond the Code</h2>
    <p class="text-slate-400 mb-12">The person behind the projects.</p>


    <div class="grid md:grid-cols-4 gap-6">
      {cards.map(card => (
        <div class="group flex flex-col rounded-2xl overflow-hidden border border-white/5 bg-white/[0.02]">
          <div class="relative aspect-[4/3] overflow-hidden">
            <img
              src={card.image}
              alt={card.title}
              class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
            style={card.image === '/astronomy.png' ? 'object-position: 60% 50%' : ''}
            />
            {card.placeholder && (
              <div class="absolute top-3 right-3 bg-black/60 text-white/50 text-xs px-2 py-1 rounded-full backdrop-blur-sm">
                placeholder
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <p class="text-slate-200 text-xs leading-relaxed">{card.description}</p>
            </div>
          </div>
          <div class="p-4">
            <p class="text-xs text-indigo-300 uppercase tracking-widest mb-1">{card.subtitle}</p>
            <h3 class="text-white font-semibold text-base leading-tight">{card.title}</h3>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
