<section id="publications" class="py-24 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-white mb-12">Publications</h2>
    <ol class="relative border-l border-white/10 space-y-12 ml-3">
      {publications.map(pub => (
        <li class="pl-10 relative">
          <span class="absolute -left-[6px] top-10 w-2.5 h-2.5 rounded-full bg-indigo-500 border-2 border-[#0f0f13]"></span>
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <span class="text-sm text-slate-500">{pub.year}</span>
            <span class={`text-sm px-3 py-0.5 rounded-full border ${badgeColors[pub.badge]}`}>
              {pub.badge}
            </span>
          </div>
          <h3 class="text-white font-semibold text-xl leading-snug mb-2">
            {pub.link ? (
              <a
                href={pub.link}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-indigo-300 transition-colors"
              >
                {pub.title} ↗
              </a>
            ) : pub.title}
          </h3>
          <p class="text-slate-400 text-base leading-relaxed">{pub.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
