---
const jobs = [
  {
    company: 'AstraZeneca — Rare Disease Unit',
    role: 'Artificial Intelligence Engineer',
    period: '2024 – Present',
    location: 'Barcelona, Spain',
    logo: '/logos/astrazeneca.png',
    highlights: [
      'Led design and delivery of enterprise GenAI solutions for knowledge retrieval and document intelligence.',
      'Built and deployed a scalable document ingestion and ETL pipeline covering multimodal extraction and orchestration.',
      'Integrated Microsoft Graph API, SharePoint, and LangSmith for real-world ingestion, observability, and validation.',
      'Supported MLOps deployment and validation of AI solutions in AWS UAT environments.',
    ],
    current: true,
  },
  {
    company: 'Spanish National Cancer Research Center (CNIO)',
    role: 'Computer Vision Engineer',
    period: '2024 – 2025',
    location: 'Madrid, Spain',
    logo: '/logos/cnio.png',
    highlights: [
      'Developed a modular Python pipeline for multiplex microscopy image analysis at single-cell resolution.',
      'Built automated workflows to quantify tumor heterogeneity, immune infiltration, and cell–cell proximity.',
      'Developed and validated a CNN-based attention-enhanced U-Net for tumor invasion front detection in H&E images.',
      'Processed large-scale microscopy datasets using HPC/GPU infrastructure.',
    ],
    current: false,
  },
  {
    company: 'Werium Solutions',
    role: 'Data Scientist & Researcher',
    period: '2022 – 2024',
    location: 'Madrid, Spain',
    logo: '/logos/werium.png',
    highlights: [
      'Processed EMG and ROM biosignals using filtering, normalization, and artifact removal techniques.',
      'Computed biomechanical metrics: coactivation index, joint range of motion, gait cadence, and phase segmentation.',
      'Performed comparative statistical analyses and generated outputs to support clinical result interpretation.',
    ],
    current: false,
  },
]
---

<section id="experience" class="py-24 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-white mb-12">Experience</h2>
    <ol class="relative border-l border-white/10 space-y-12 ml-3">
      {jobs.map(job => (
        <li class="pl-8 relative">
          <span class={`absolute -left-[6px] top-7 w-2.5 h-2.5 rounded-full border-2 border-[#0f0f13] ${job.current ? 'bg-indigo-400' : 'bg-slate-600'}`}></span>
          <div class="flex items-center gap-4 mb-4">
            <img
              src={job.logo}
              alt={job.company}
              class="w-14 h-14 rounded-xl object-contain shrink-0"
              onerror="this.style.display='none'"
            />
            <div>
              <div class="flex flex-wrap items-center gap-3 mb-1">
                <span class="text-sm text-slate-500">{job.period}</span>
                <span class="text-sm text-slate-500">·</span>
                <span class="text-sm text-slate-500">{job.location}</span>
                {job.current && (
                  <span class="text-xs px-2.5 py-0.5 rounded-full border bg-indigo-500/15 text-indigo-300 border-indigo-500/30">
                    Current
                  </span>
                )}
              </div>
              <h3 class="text-white font-semibold text-xl leading-snug">{job.company}</h3>
              <p class="text-indigo-300 text-sm mt-0.5">{job.role}</p>
            </div>
          </div>
          <ul class="space-y-2">
            {job.highlights.map(h => (
              <li class="flex items-start gap-2 text-slate-400 text-sm leading-relaxed">
                <span class="mt-2 w-1 h-1 rounded-full bg-slate-600 shrink-0"></span>
                {h}
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </div>
</section>
