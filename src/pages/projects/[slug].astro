---
import Layout from '../../layouts/Layout.astro'
import { projects, getProject } from '../../data/projects'
import { icons, iconClass } from '../../data/icons'

export function getStaticPaths() {
  return projects.map(p => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params
const project = getProject(slug!)

if (!project) return Astro.redirect('/')

const badgeColors: Record<string, string> = {
  'Computer Vision & Generative AI': 'bg-amber-500/20 text-amber-300 border-amber-500/30',
  'Generative AI':                   'bg-amber-500/20 text-amber-300 border-amber-500/30',
  'Computer Vision':                 'bg-violet-500/20 text-violet-300 border-violet-500/30',
  'Data Science':                    'bg-rose-500/20 text-rose-300 border-rose-500/30',
  'Virtual Reality':                 'bg-blue-500/20 text-blue-300 border-blue-500/30',
  'Deep Learning':                   'bg-emerald-500/20 text-emerald-300 border-emerald-500/30',
}
---

<Layout title={`${project.title} — Daniel Anchuela`} description={project.tagline}>
  <div class="min-h-screen">

    <!-- Top nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-[#0f0f13]/80 backdrop-blur-md border-b border-white/5">
      <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/#projects" class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Back
        </a>
        <a href="/" class="font-semibold text-white tracking-tight text-sm">Daniel Anchuela</a>
      </div>
    </nav>

    {project.heroImage && (
      <div class="w-full pt-16">
        <img
          src={project.heroImage}
          alt={project.title}
          class="w-full max-h-[600px] object-cover object-[center_85%]"
        />
        <div id="hero-end" class="scroll-mt-[60vh]"></div>
      </div>
    )}

    <main id="content" class="max-w-4xl mx-auto px-6 pt-12 pb-24 scroll-mt-16">

      <!-- Header -->
      <div class="mb-16">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="text-sm text-slate-500">{project.year}</span>
          {project.badges?.map(b => (
            <span class={`text-xs px-2.5 py-0.5 rounded-full border ${badgeColors[b] ?? 'bg-white/5 text-slate-400 border-white/10'}`}>
              {b}
            </span>
          ))}
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{project.title}</h1>
        <p class="text-lg text-slate-400 max-w-2xl leading-relaxed">{project.tagline}</p>

        <!-- GitHub links -->
        <div class="flex flex-wrap gap-3 mt-8">
          {project.githubRepos ? (
            project.githubRepos.map(repo => (
              <a
                href={repo.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2 border border-white/10 hover:border-white/30 text-slate-300 hover:text-white rounded-lg text-sm transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                {repo.label}
              </a>
            ))
          ) : project.github ? (
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 border border-white/10 hover:border-white/30 text-slate-300 hover:text-white rounded-lg text-sm transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              View on GitHub
            </a>
          ) : (
            <span class="flex items-center gap-2 px-4 py-2 border border-white/5 text-slate-600 rounded-lg text-sm cursor-default">
              Private / Coming soon
            </span>
          )}
          {project.liveUrl && (
            <a
              href={project.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 bg-indigo-600/20 hover:bg-indigo-600/30 border border-indigo-500/30 text-indigo-300 hover:text-indigo-200 rounded-lg text-sm transition-colors"
            >
              ↗ SideQuest
            </a>
          )}
        </div>
      </div>

      <!-- Body -->
      <div class="grid md:grid-cols-3 gap-12">
        <div class="md:col-span-2 space-y-12">

          <!-- Overview -->
          <section>
            <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-4">Overview</h2>
            <p class="text-slate-300 leading-relaxed text-[1.05rem]">{project.description}</p>
          </section>

          <!-- Context -->
          <section>
            <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-4">Context</h2>
            <p class="text-slate-300 leading-relaxed text-[1.05rem]">{project.context}</p>
          </section>

          <!-- Highlights -->
          <section>
            <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-4">Key highlights</h2>
            <ul class="space-y-3">
              {project.highlights.map(h => (
                <li class="flex gap-3 text-slate-300 leading-relaxed">
                  <span class="mt-2 w-1.5 h-1.5 rounded-full bg-indigo-400 shrink-0"></span>
                  {h}
                </li>
              ))}
            </ul>
          </section>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-8">
          {project.metrics && project.metrics.length > 0 && (
            <div>
              <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-4">{project.metricsLabel ?? 'Results'}</h2>
              <div class="space-y-3">
                {project.metrics.map(m => (
                  <div class="bg-[#1e1e2a] border border-white/5 rounded-xl p-3">
                    <p class="text-xl font-bold text-white">{m.value}</p>
                    <p class="text-xs text-slate-500 mt-0.5">{m.label}</p>
                  </div>
                ))}
              </div>
            </div>
          )}
          <div>
            <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-4">Tech stack</h2>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="flex items-center gap-1 px-2.5 py-1 text-xs bg-[#1e1e2a] border border-white/10 text-slate-300 rounded">
                  {icons[tag] && <img src={icons[tag]} alt="" class={`shrink-0 ${iconClass(icons[tag])}`} />}
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <div>
            <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-4">Year</h2>
            <p class="text-slate-300">{project.year}</p>
          </div>

          {project.badges && project.badges.length > 0 && (
            <div>
              <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-4">Type</h2>
              <div class="flex flex-wrap gap-2">
                {project.badges.map(b => (
                  <span class={`text-xs px-2.5 py-1 rounded-full border ${badgeColors[b] ?? 'bg-white/5 text-slate-400 border-white/10'}`}>
                    {b}
                  </span>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>

      <!-- Image gallery -->
      {project.images && project.images.length > 0 && (
        <div class="mt-16">
          <h2 class="text-xs uppercase tracking-widest text-slate-500 mb-6">Gallery</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {project.images.map(img => (
              <figure class="group overflow-hidden rounded-xl border border-white/5 bg-[#16161d]">
                <button class="w-full lightbox-trigger" data-src={img.url} data-caption={img.caption}>
                  <img
                    src={img.url}
                    alt={img.caption}
                    class="w-full object-cover aspect-video group-hover:scale-105 transition-transform duration-300 cursor-zoom-in"
                    loading="lazy"
                  />
                </button>
                <figcaption class="px-3 py-2 text-xs text-slate-500">{img.caption}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      )}

      <!-- Lightbox -->
      <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 p-4 cursor-zoom-out" onclick="closeLightbox()">
        <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] object-contain rounded-lg shadow-2xl" />
        <p id="lightbox-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-sm text-slate-400 bg-black/60 px-4 py-1 rounded-full"></p>
      </div>

      <script>
        const lb = document.getElementById('lightbox')!
        const lbImg = document.getElementById('lightbox-img') as HTMLImageElement
        const lbCap = document.getElementById('lightbox-caption')!

        document.querySelectorAll('.lightbox-trigger').forEach(btn => {
          btn.addEventListener('click', () => {
            const src = (btn as HTMLElement).dataset.src!
            const caption = (btn as HTMLElement).dataset.caption!
            lbImg.src = src
            lbImg.alt = caption
            lbCap.textContent = caption
            lb.classList.remove('hidden')
            lb.classList.add('flex')
            document.body.style.overflow = 'hidden'
          })
        })

        lb.addEventListener('click', () => {
          lb.classList.add('hidden')
          lb.classList.remove('flex')
          document.body.style.overflow = ''
        })

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            lb.classList.add('hidden')
            lb.classList.remove('flex')
            document.body.style.overflow = ''
          }
        })
      </script>

      <!-- Footer nav -->
      <div class="mt-20 pt-8 border-t border-white/5">
        <a href="/#projects" class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Back to projects
        </a>
      </div>

    </main>
  </div>
</Layout>
